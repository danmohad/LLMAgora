{
  // Directory for generated manifest, status, summaries, and case folders.
  "sweep_root": "../outputs/sweeps/example",
  // Free-form description copied into generated sweep metadata.
  "notes": "Example parameter sweep",
  // Maximum number of case processes to run concurrently.
  "max_parallel_jobs": 2,
  // Stop scheduling new cases after the first failed or interrupted case.
  "stop_on_error": false,
  // Independent repeats generated for each Cartesian parameter combination.
  "number_of_repeats": 1,

  // Settings used by `agora sweep aggregate`.
  "aggregation": {
    // Aggregate JSON path, resolved relative to sweep_root.
    "output_path": "aggregate_analysis.json",
    // Optional offline analysis overrides for completed case snapshots.
    "analysis": {
      // Semantic metrics to compute during aggregation, or [] to reuse saved artifacts only.
      "semantic_analysis_metrics": [],
      // Semantic backend required when semantic_analysis_metrics is non-empty.
      "semantic_similarity_method": null,
      // Semantic model required when semantic_analysis_metrics is non-empty.
      "semantic_similarity_model": null,
      // Device for semantic model inference: null, cpu, mps, or cuda.
      "semantic_similarity_device": null,
      // Persona metrics to compute during aggregation, or [] to reuse saved artifacts only.
      "persona_analysis_metrics": [],
      // Persona scoring model required when persona_analysis_metrics is non-empty.
      "persona_scoring_model": null,
      // Whether persona scoring prints detailed progress.
      "persona_scoring_verbose": false,
      // Number of scoring samples required when persona_analysis_metrics is non-empty.
      "persona_score_samples": null,
      // Whether to save plots for aggregate-time analyses.
      "save_plots": false,
      // Whether to display aggregate-time plots; requires save_plots=true.
      "show_plots": false
    },
    // Whether to run an extra aggregate NLI pass over completed snapshots.
    "include_nli": false,
    // HuggingFace NLI model override, or null for the package default.
    "nli_model_name": null,
    // Whether to run an extra aggregate emotion-classification pass.
    "include_emotions": false,
    // HuggingFace emotion model override, or null for the package default.
    "emotion_model_name": null,
    // Device for aggregate-only HuggingFace analyses: null, cpu, mps, or cuda.
    "device": null,
    // Decision-label stripping mode for aggregate semantic/NLI outputs: off, include, or only.
    "strip_decision_labels": "off"
  },

  // Base single-run config copied into every generated case.
  "base": {
    // Any scenario ID from data/scenarios.json.
    "scenario_id": "promotion_committee",
    // null disables incentive context; otherwise choose positive or negative.
    "incentive_direction": "positive",
    // Selects the historical or future module under the chosen incentive direction.
    "incentive_type": "historical",
    // Prompt template set from data/prompts.json.
    "prompt_set": "default",
    // Any OpenRouter model identifier available to your account.
    "model": "openai/gpt-4o-mini",
    // Number of debate rounds after optional pre-interviews.
    "num_turns": 1,
    // Event order within each agent turn; include public_utterance and optional private/survey events.
    "subturn_event_order": [
      "public_utterance",
      "private_utterance",
      "public_survey",
      "private_survey"
    ],
    // true prints progress and transcript details into each case log.
    "verbose": false,
    // Retention only; private_utterance in subturn_event_order controls whether reflections run.
    "keep_private_reflection": false,
    // Retention only; pre-interviews run before debate turns.
    "keep_pre_interview": false,
    // Retention only; post-interviews run after debate turns.
    "keep_post_interview": false,
    // Retention only; public_survey in subturn_event_order controls whether public surveys run.
    "keep_public_survey": false,
    // Retention only; private_survey in subturn_event_order controls whether private surveys run.
    "keep_private_survey": false,
    // Semantic metrics to run; [] skips local embedding/NLI analysis.
    "semantic_analysis_metrics": [],
    // Required when semantic_analysis_metrics is non-empty.
    "semantic_similarity_method": null,
    // Required when semantic_analysis_metrics is non-empty.
    "semantic_similarity_model": null,
    // Semantic model device: null, cpu, mps, or cuda.
    "semantic_similarity_device": null,
    // Persona adherence metrics to run; [] skips persona scoring calls.
    "persona_analysis_metrics": [],
    // Required when persona_analysis_metrics is non-empty.
    "persona_scoring_model": null,
    // true prints detailed persona scoring progress.
    "persona_scoring_verbose": false,
    // Required when persona_analysis_metrics is non-empty.
    "persona_score_samples": null,
    // Whether to save plots for enabled analyses.
    "save_plots": false,
    // Whether to display plots while running; requires save_plots=true.
    "show_plots": false,
    // Whether to read load_dir/debate_snapshot.json.
    "load_snapshot": false,
    // Required snapshot directory when load_snapshot=true.
    "load_dir": null,
    // Ignored by generated cases; the sweep generator forces save_snapshot=true.
    "save_snapshot": false,
    // Scenario catalog path, resolved relative to this config file.
    "catalog_path": "scenarios.json",
    // Prompt catalog path, resolved relative to this config file.
    "prompts_path": "prompts.json"
  },

  // Parameter sweep overlaid on base; multiple keys form a Cartesian product.
  "sweep": {
    // Generate one case for each incentive_type value.
    "incentive_type": ["historical", "future"]

    // For list-valued fields, each candidate is the complete list value:
    // "subturn_event_order": [["public_utterance"], ["public_utterance", "private_utterance"]],
    // "semantic_analysis_metrics": [[], ["self_consistency"]],
    // "persona_analysis_metrics": [[], ["public_per_turn", "full_debate_public"]]
  }
}
