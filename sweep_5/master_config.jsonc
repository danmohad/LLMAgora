{
  // Root directory that will hold manifest/status plus one leaf folder per case.
  "sweep_root": "sweep_5",

  // Batch runner defaults.
  "max_parallel_jobs": 8,
  "stop_on_error": false,
  // Total runs to generate for each Cartesian case.
  // 1 means one run per combination; 3 means three separate case folders per combination.
  "number_of_repeats": 3,
  "notes": "Exploratory parameter sweep",

  "base": {
    // Scenario selection. See data/scenarios.json for available IDs.
    "prompt_set": "default",

    // Debate length and event ordering.
    "num_turns": 5,
    "subturn_event_order": [
      "private_survey",
      "private_utterance",
      "public_survey",
      "public_utterance"
    ],
    "verbose": false,

    // Private reflection retention.
    "keep_private_reflection": false,

    // Pre/post interviews run by default.
    // These flags only control whether those notes are retained in local memory.
    "keep_pre_interview": false,
    "keep_post_interview": false,

    // Surveys.
    "keep_public_survey": false,
    "keep_private_survey": false,

    // Semantic similarity analysis.
    // Options: self_consistency, cross_agent_public_alignment, cross_agent_private_alignment
    "semantic_analysis_metrics": [],
    "semantic_similarity_method": null, // cosine | nli
    "semantic_similarity_model": null, // defaults by method
    "semantic_similarity_device": null, // null | cpu | mps

    // Persona adherence analysis.
    // Options: public_per_turn, private_per_turn, public_cumulative,
    //          private_cumulative, full_debate_public, full_debate_private
    "persona_analysis_metrics": [],
    "persona_scoring_model": null,
    "persona_scoring_verbose": false,
    "persona_score_samples": null,

    // Plotting.
    "save_plots": false,
    "show_plots": false, // requires save_plots=true

    // Snapshot handling.
    "load_snapshot": false,
    "load_dir": null, // required when load_snapshot=true
    "save_snapshot": true,

    // Input files.
    "catalog_path": "../LLMAgora/data/scenarios.json",
    "prompts_path": "../LLMAgora/data/prompts.json"

    // Per-case output fields are intentionally omitted here.
    // The generator injects a fixed output_dir for each case.
  },

  "sweep": {
    "model": [
      "openai/gpt-5.4",
			"anthropic/claude-sonnet-4.6"	
    ],
    "incentive_direction": ["positive", null, "negative"],
    "incentive_type": ["future", "historical"],
    "scenario_id":[
			"promotion_committee_max_divergence",
			"ngo_climate_endorsement_max_divergence",
			"faculty_manuscript_submission_max_divergence"
		]
  }
}
